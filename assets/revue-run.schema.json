{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://revue.dev/schema/revue-run.schema.json",
  "title": "revue.review.v1",
  "description": "Schema-versioned result artifact for a revüe review run.",
  "type": "object",
  "required": ["schema", "mode", "request", "stakeholder", "inputs", "evidence", "verdict"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "revue.review.v1" },
    "runId": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["design-handoff", "product-shaping", "implementation-review", "client-delivery", "platform-build"]
    },
    "produces": {
      "type": "string",
      "enum": ["review", "creative-production"],
      "default": "review",
      "description": "'review' checks existing work (default). 'creative-production' means revüe is generating something new, which triggers the brief, options, and output-audit gates."
    },
    "dryRun": { "type": "boolean", "default": true },
    "request": { "type": "string", "minLength": 1 },
    "stakeholder": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": { "type": "string" },
          "ref": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "constraints": { "type": "object" },
    "proofRequired": { "type": "array", "items": { "type": "string" } },
    "gates": { "type": "array", "items": { "type": "string" } },
    "brief": {
      "type": "object",
      "description": "Required creative brief for 'produces': 'creative-production' runs (references/creative-brief.md). scripts/validate-run.py enforces these as a batched completeness gate.",
      "required": ["deliverable", "format", "tier", "sources", "handoffPageRead", "designSystemLock", "hardNos"],
      "properties": {
        "deliverable": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "minLength": 1 },
        "tier": {
          "type": "string",
          "enum": ["Standard", "Premium", "Custom"],
          "description": "references/creative-brief.md cascade: sets the craft bar (references/elevate.md for Premium), the model tier (references/model-routing.md), and the audit bar (scripts/validate-output.py --tier)."
        },
        "sources": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "handoffPageRead": { "type": "boolean" },
        "designSystemLock": { "type": "string", "description": "Reference/path to the lock (assets/*.lock.json or the run's top-level designSystemLock object)." },
        "hardNos": { "type": "array", "items": { "type": "string" } },
        "structure": {
          "type": "object",
          "description": "Optional structure spec for references/brief-conformance.md. When present, scripts/validate-conformance.py's result is required (as the run's top-level 'conformance') before a 'ship' verdict.",
          "properties": {
            "requiredSections": { "type": "array", "items": { "type": "string" } },
            "sectionOrder": { "type": "boolean" },
            "forbiddenElements": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["pattern", "why"],
                "properties": { "pattern": { "type": "string" }, "why": { "type": "string" } }
              }
            },
            "requiredPlaceholders": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "tierSignoff": {
      "type": "object",
      "description": "Required before a 'ship' verdict when brief.tier is 'Custom' — Custom is human-led, not autonomously graded (references/creative-brief.md).",
      "required": ["by"],
      "properties": {
        "by": { "type": "string", "minLength": 1 },
        "note": { "type": "string" }
      }
    },
    "designSystemLock": {
      "type": "object",
      "description": "The machine-checkable lock (references/design-system-lock.md) the deliverable is audited against.",
      "properties": {
        "colors": { "type": "array", "items": { "type": "string" } },
        "typography": { "type": "array", "items": { "type": "string" } },
        "hardNos": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pattern", "why"],
            "properties": {
              "pattern": { "type": "string" },
              "why": { "type": "string" }
            }
          }
        }
      }
    },
    "options": {
      "type": "array",
      "description": "2-3 distinct, lock-compliant creative concepts (references/options-and-refine.md).",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "summary", "distinctionAxis", "lockCompliant"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "distinctionAxis": { "type": "string", "description": "What makes this concept genuinely different from the others, not just relabeled." },
          "lockCompliant": { "type": "boolean" }
        }
      }
    },
    "optionFeedback": {
      "type": "array",
      "description": "Reject-refine feedback per option, folded into the brief before the next round (references/options-and-refine.md).",
      "items": {
        "type": "object",
        "required": ["optionId", "decision"],
        "properties": {
          "optionId": { "type": "string" },
          "decision": { "type": "string", "enum": ["keep", "kill", "change"] },
          "note": { "type": "string" }
        }
      }
    },
    "board": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["panelist", "findings"],
        "properties": {
          "panelist": {
            "type": "string",
            "enum": ["critique", "aggressive", "conservative", "proof", "implementation", "stakeholder", "synthesis"]
          },
          "findings": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "statement"],
        "properties": {
          "category": { "type": "string", "enum": ["source", "action", "result", "limitation"] },
          "statement": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      }
    },
    "scorecard": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "status"],
        "properties": {
          "check": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "partial", "fail", "not applicable"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "outputAudit": {
      "type": "object",
      "description": "Result of scripts/validate-output.py against the design-system lock (references/output-audit.md). Required (and must be pass: true) before a 'ship' verdict on a creative-production run.",
      "required": ["pass"],
      "properties": {
        "deliverablePath": { "type": "string" },
        "lockPath": { "type": "string" },
        "colorsFound": { "type": "array", "items": { "type": "string" } },
        "colorsOutOfLock": { "type": "array", "items": { "type": "string" } },
        "hardNoHits": { "type": "array", "items": { "type": "string" } },
        "elevateChecks": {
          "type": "array",
          "description": "Present only when audited with --tier premium (references/elevate.md).",
          "items": {
            "type": "object",
            "required": ["check", "status"],
            "properties": {
              "check": { "type": "string" },
              "status": { "type": "string", "enum": ["pass", "fail"] },
              "detail": { "type": "string" }
            }
          }
        },
        "elevatePass": { "type": "boolean", "description": "Required true before 'ship' when brief.tier is 'Premium'." },
        "pass": { "type": "boolean" }
      }
    },
    "conformance": {
      "type": "object",
      "description": "Result of scripts/validate-conformance.py against the brief's structure spec (references/brief-conformance.md). Required (and must be pass: true) before a 'ship' verdict, only when brief.structure is declared.",
      "required": ["pass"],
      "properties": {
        "deliverablePath": { "type": "string" },
        "structurePath": { "type": "string" },
        "sectionsFound": { "type": "array", "items": { "type": "string" } },
        "missingSections": { "type": "array", "items": { "type": "string" } },
        "orderViolations": { "type": "array", "items": { "type": "string" } },
        "forbiddenHits": { "type": "array", "items": { "type": "string" } },
        "missingPlaceholders": { "type": "array", "items": { "type": "string" } },
        "pass": { "type": "boolean" }
      }
    },
    "verdict": {
      "type": "object",
      "required": ["value", "reason"],
      "properties": {
        "value": { "type": "string", "enum": ["ship", "ship with changes", "caution", "block"] },
        "reason": { "type": "string" },
        "requiredProof": { "type": "string" },
        "nextAction": { "type": "string" },
        "assumptionDependent": { "type": "boolean" },
        "assumption": { "type": "string" },
        "flipsTo": { "type": "string", "enum": ["ship", "ship with changes", "caution", "block"] }
      }
    },
    "changedSinceLastRun": { "type": "boolean" },
    "inputsFingerprint": { "type": "string" },
    "previousVerdict": { "type": "string" },
    "decisionsNeeded": { "type": "array", "items": { "type": "string" } },
    "pathToShip": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "owner"],
        "properties": {
          "item": { "type": "string" },
          "owner": { "type": "string", "enum": ["agent", "human"] },
          "unlocks": { "type": "string" }
        }
      }
    },
    "trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step"],
        "properties": {
          "step": { "type": "string" },
          "durationMs": { "type": "number" },
          "modelTier": {
            "type": "string",
            "enum": ["fast", "standard", "deep", "deep-coding"],
            "description": "references/model-routing.md. Gate/validator steps (brief-gate, design-system-lock-check, options-lock-check, output-audit, self-check, validate-run, validate-output, validate-evidence) must be 'fast'."
          },
          "model": { "type": "string", "description": "Runtime-confirmed model identifier actually used. Omit when the runtime does not expose it." }
        }
      }
    }
  }
}
